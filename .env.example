# ── Okta ─────────────────────────────────────────────────────────────────────
# Custom authorization server URL (recommended over org-level server)
# Format: https://<tenant>.okta.com/oauth2/<authServerId>
# Example: https://acme.okta.com/oauth2/aus1ab2cd3ef4gh5ij
OKTA_ISSUER=https://your-tenant.okta.com/oauth2/your-auth-server-id

# Audience claim the Okta access token is scoped to.
# Must match what you set in the Okta app's "Audience" field.
# Example: api://secrets-mcp
OKTA_AUDIENCE=api://your-audience

# Okta OIDC app client ID (used in client mcp.json configs, not by the server)
OKTA_CLIENT_ID=0oa1ab2cd3ef4gh5ij

# ── AWS (local dev / testing only) ───────────────────────────────────────────
AWS_REGION=us-east-1
# AWS_PROFILE=your-named-profile
